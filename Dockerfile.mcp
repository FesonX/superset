# MCP service image — Superset lean base + fastmcp.
#
# Build (two steps):
#
#   # 1. Build the lean base from the main Dockerfile
#   docker build --target lean -t superset:lean-<sha> .
#
#   # 2. Build the MCP image on top
#   docker build -f Dockerfile.mcp \
#     --build-arg LEAN_IMAGE=superset:lean-<sha> \
#     -t superset:mcp-<sha> .
#
# The MCP service connects to the same database and uses the same
# superset_config.py as the Superset web server.
#
# Requirements are pinned in requirements/mcp.txt.
# Regenerate with: ./scripts/uv-pip-compile.sh

ARG LEAN_IMAGE=apache/superset:latest
FROM ${LEAN_IMAGE}

ENV SUPERSET_HOME="/app/superset_home"

# Need root to install into the venv
USER root

# Install MCP-specific requirements on top of the lean base.
# uv skips packages that are already installed (base.txt deps),
# so only fastmcp and its unique transitive dependencies are added.
COPY requirements/mcp.txt requirements/mcp.txt
RUN --mount=type=cache,target=${SUPERSET_HOME}/.cache/uv \
    uv pip install --python /app/.venv -r requirements/mcp.txt

USER superset

EXPOSE 5008
CMD ["superset", "mcp", "run", "--host", "0.0.0.0", "--port", "5008"]
